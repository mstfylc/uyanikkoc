{
  "name": "uyanik",
  "private": true,
  "scripts": {
    "dev:web": "turbo run dev --filter=@uyanik/web",
    "dev:real": "powershell -ExecutionPolicy Bypass -File ./scripts/start-real-server.ps1",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test:unit": "turbo run test",
    "test:e2e": "pnpm --filter @uyanik/web test:e2e",
    "db:generate": "pnpm --filter @uyanik/database generate",
    "db:migrate": "pnpm --filter @uyanik/database migrate",
    "db:seed": "pnpm --filter @uyanik/database seed",
    "db:verify-alpha": "pnpm --filter @uyanik/database verify:alpha"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "packageManager": "pnpm@9.15.0"
}
