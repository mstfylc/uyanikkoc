# Vercel / production - enter these in Vercel Dashboard -> Settings -> Environment Variables
#
# Vercel Project Settings:
#   Root Directory: apps/web
#   "Include source files outside of the Root Directory": Enabled
#   Framework: Next.js
#   Build Command (override): cd ../.. && pnpm db:generate && pnpm --filter @uyanik/web build
#   Install Command (override): cd ../.. && pnpm install

NODE_ENV=production

# PostgreSQL. Supabase pooler URL is recommended.
DATABASE_URL=

# NextAuth/Auth.js - production required. At least one secret must be non-empty.
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=

# Live site URL, no trailing slash.
AUTH_URL=https://uyanikkoc.com
NEXTAUTH_URL=https://uyanikkoc.com

# Production required: memory/demo auth is forbidden.
# If NODE_ENV=production and this is true/1, the app fails fast.
DEMO_AUTH_ALLOW_IN_MEMORY=false

# Fixed product decisions.
SINGLE_BRANCH_MODE=true
AI_COACH_ENABLED=false

# Transactional email (Resend)
RESEND_API_KEY=
MAIL_FROM="Uyanik Koc <noreply@uyanikkoc.com>"

# SMS / OTP (Netgsm)
# SMS_PROVIDER=mock kalirsa gercek SMS gitmez. Canli SMS icin netgsm yapin.
SMS_PROVIDER=netgsm
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=UYANIKKOC
SMS_API_USER=
SMS_API_KEY=
SMS_SENDER_TITLE=UYANIKKOC

# Seed-compatible demo org/branch ids. Optional.
DEFAULT_ORGANIZATION_ID=org_demo_001
DEFAULT_BRANCH_ID=branch_demo_001

# Metronic assets are gitignored. Do not commit licensed assets.
# Copy public/assets/metronic/ through the deployment pipeline if needed.
