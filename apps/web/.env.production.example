# Vercel / production — değerleri Vercel Dashboard → Settings → Environment Variables içine gir
#
# Vercel Project Settings (önemli):
#   Root Directory: apps/web
#   "Include source files outside of the Root Directory": Enabled
#   Framework: Next.js
#   Build Command (override): cd ../.. && pnpm db:generate && pnpm --filter @uyanik/web build
#   Install Command (override): cd ../.. && pnpm install

NODE_ENV=production

# PostgreSQL (Supabase connection string — pooler URL önerilir)
DATABASE_URL=

# NextAuth — openssl rand -base64 32 ile üret
AUTH_SECRET=
NEXTAUTH_SECRET=

# Canlı site URL (trailing slash yok)
AUTH_URL=https://uyanikkoc.com
NEXTAUTH_URL=https://uyanikkoc.com

# Production: bellek modu kapalı
DEMO_AUTH_ALLOW_IN_MEMORY=false

# Değişmez kararlar
SINGLE_BRANCH_MODE=true
AI_COACH_ENABLED=false

# Seed ile uyumlu demo org/branch (opsiyonel)
DEFAULT_ORGANIZATION_ID=org_demo_001
DEFAULT_BRANCH_ID=branch_demo_001

# Metronic asset'leri gitignore'da — deploy sonrası public/assets/metronic/ klasörünü
# Vercel'e manuel yükle veya build pipeline'a kopyala (lisanslı dosyalar repoda yok).
