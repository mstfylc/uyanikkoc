{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "paths": {
      "@/*": ["./src/*"],
      "@uyanik/shared": ["../../packages/shared/src/index.ts"],
      "@uyanik/tokens": ["../../packages/tokens/src/index.ts"]
    }
  },
  "include": ["app/**/*.tsx", "src/**/*.ts", "src/**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
