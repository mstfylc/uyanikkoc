{
  "expo": {
    "name": "Uyanik Koc",
    "slug": "uyanik-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "uyanik",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "android": {
      "package": "com.uyanik.mobile"
    },
    "ios": {
      "bundleIdentifier": "com.uyanik.mobile"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://uyanikkoc.vercel.app"
    }
  }
}
