generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DbRole {
  STUDENT
  COACH
  PARENT
  BRANCH_MANAGER
  ORG_ADMIN
}

enum AssignmentType {
  homework
  exam_prep
  reading
  practice
  other
}

enum AssignmentPriority {
  low
  medium
  high
}

enum AssignmentStatus {
  pending
  in_progress
  completed
  cancelled
}

enum TopicExamType {
  TYT
  AYT
  LGS
  GENEL
}

enum ResultExamType {
  TYT
  AYT
  LGS
}

model Organization {
  id       String   @id
  name     String
  branches Branch[]
  users    User[]

  @@map("organizations")
}

model Branch {
  id             String       @id
  organizationId String
  name           String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]
  assignments    Assignment[]
  onlineExams    OnlineExam[]

  @@index([organizationId])
  @@map("branches")
}

model User {
  id             String          @id
  email          String          @unique
  passwordHash   String
  role           DbRole
  organizationId String
  branchId       String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  studentProfile StudentProfile?
  coachProfile   CoachProfile?
  parentProfile  ParentProfile?
  paymentMethods PaymentMethod[]
  subscriptions  Subscription[]  @relation("PayerSubscriptions")
  invoices       Invoice[]
  supportTickets SupportTicket[]

  @@index([organizationId, branchId])
  @@map("users")
}

model StudentProfile {
  id                String       @id
  userId            String       @unique
  parentId          String?
  motivationEnabled Boolean      @default(true)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent            ParentProfile? @relation(fields: [parentId], references: [id], onDelete: SetNull)
  assignments       Assignment[] @relation("StudentAssignments")
  subjects          Subject[]
  examResults       ExamResult[]
  notifications     Notification[]
  coachLinks        CoachStudent[]
  subscriptions     Subscription[]
  rating            CoachRating?
  optikSubmissions  OptikSubmission[]
  motivationMessages MotivationMessage[]
  coachTasks        CoachTask[]

  @@map("student_profiles")
}

model CoachProfile {
  id          String               @id
  userId      String               @unique
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments Assignment[]         @relation("CoachAssignments")
  templates   AssignmentTemplate[]
  students    CoachStudent[]
  ratings     CoachRating[]
  tasks       CoachTask[]
  announcements CoachAnnouncement[]

  @@map("coach_profiles")
}

model ParentProfile {
  id            String           @id
  userId        String           @unique
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  children      StudentProfile[]
  notifications Notification[]

  @@map("parent_profiles")
}

model Assignment {
  id          String             @id @default(cuid())
  title       String
  description String?
  type        AssignmentType     @default(homework)
  priority    AssignmentPriority @default(medium)
  status      AssignmentStatus   @default(pending)
  subject     String?
  dueDate     DateTime?
  coachId     String
  studentId   String
  parentId    String
  branchId    String
  completed   Boolean            @default(false)
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  coach       CoachProfile       @relation("CoachAssignments", fields: [coachId], references: [id], onDelete: Cascade)
  student     StudentProfile     @relation("StudentAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  branch      Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([parentId])
  @@index([branchId])
  @@index([status])
  @@map("assignments")
}

model Subject {
  id        String        @id @default(cuid())
  studentId String
  examType  TopicExamType
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topics    Topic[]

  @@index([studentId])
  @@map("subjects")
}

model Topic {
  id        String         @id @default(cuid())
  subjectId String
  studentId String
  name      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  progress  TopicProgress?

  @@index([subjectId])
  @@index([studentId])
  @@map("topics")
}

model TopicProgress {
  id          String    @id @default(cuid())
  topicId     String    @unique
  studentId   String
  completed   Boolean   @default(false)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt
  topic       Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("topic_progress")
}

model ExamResult {
  id        String             @id @default(cuid())
  studentId String
  examType  ResultExamType
  label     String?
  takenAt   DateTime
  totalNet  Float
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  student   StudentProfile     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjects  ExamSubjectResult[]

  @@index([studentId])
  @@index([takenAt])
  @@map("exam_results")
}

model ExamSubjectResult {
  id           String     @id @default(cuid())
  examResultId String
  subjectName  String
  correct      Int
  wrong        Int
  net          Float
  examResult   ExamResult @relation(fields: [examResultId], references: [id], onDelete: Cascade)

  @@index([examResultId])
  @@map("exam_subject_results")
}

model Notification {
  id        String          @id @default(cuid())
  studentId String?
  parentId  String?
  title     String
  body      String
  read      Boolean         @default(false)
  sourceKey String?         @unique
  createdAt DateTime        @default(now())
  student   StudentProfile? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent    ParentProfile?  @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([parentId])
  @@map("notifications")
}

model MessageThread {
  id        String         @id @default(cuid())
  coachId   String
  studentId String?
  parentId  String?
  kind      ThreadKind     @default(dm)
  name      String?
  title     String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  messages  Message[]
  members   ThreadMember[]

  @@index([coachId])
  @@index([studentId])
  @@index([parentId])
  @@map("message_threads")
}

model Message {
  id         String        @id @default(cuid())
  threadId   String
  senderRole DbRole
  body       String
  createdAt  DateTime      @default(now())
  thread     MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("messages")
}

model AssignmentTemplate {
  id          String       @id @default(cuid())
  coachId     String
  title       String
  description String?
  type        AssignmentType @default(homework)
  priority    AssignmentPriority @default(medium)
  subject     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  coach       CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@map("assignment_templates")
}

model CoachStudent {
  id        String         @id @default(cuid())
  coachId   String
  studentId String
  createdAt DateTime       @default(now())
  coach     CoachProfile   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([coachId, studentId])
  @@index([coachId])
  @@index([studentId])
  @@map("coach_students")
}

enum BillingCycle {
  monthly
  annual
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
}

enum InvoiceStatus {
  paid
  pending
  failed
}

enum CardBrand {
  visa
  mastercard
}

model BillingPlan {
  id            String         @id
  name          String
  tagline       String
  monthly       Int
  annual        Int
  popular       Boolean        @default(false)
  features      String[]
  sortOrder     Int            @default(0)
  active        Boolean        @default(true)
  subscriptions Subscription[]

  @@map("billing_plans")
}

model PaymentMethod {
  id            String         @id @default(cuid())
  userId        String
  brand         CardBrand
  last4         String
  holder        String
  expMonth      Int
  expYear       Int
  isDefault     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  invoices      Invoice[]

  @@index([userId])
  @@map("payment_methods")
}

model Subscription {
  id              String             @id @default(cuid())
  payerUserId     String
  studentId       String?
  planId          String
  cycle           BillingCycle
  status          SubscriptionStatus @default(active)
  autoRenew       Boolean            @default(true)
  startedAt       DateTime           @default(now())
  renewsAt        DateTime
  canceledAt      DateTime?
  paymentMethodId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  payer           User               @relation("PayerSubscriptions", fields: [payerUserId], references: [id], onDelete: Cascade)
  student         StudentProfile?    @relation(fields: [studentId], references: [id], onDelete: SetNull)
  plan            BillingPlan        @relation(fields: [planId], references: [id], onDelete: Restrict)
  paymentMethod   PaymentMethod?     @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  invoices        Invoice[]

  @@index([payerUserId])
  @@index([studentId])
  @@map("subscriptions")
}

model Invoice {
  id              String         @id
  subscriptionId  String
  payerUserId     String
  planId          String
  cycle           BillingCycle
  amount          Int
  status          InvoiceStatus  @default(paid)
  installments    Int            @default(1)
  methodLabel     String
  paymentMethodId String?
  issuedAt        DateTime       @default(now())
  subscription    Subscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payer           User           @relation(fields: [payerUserId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([payerUserId])
  @@map("invoices")
}

enum SupportCategory {
  teknik
  oneri
  hesap
  diger
}

enum SupportStatus {
  open
  answered
  closed
}

model SupportTicket {
  id        String          @id
  userId    String
  role      DbRole
  category  SupportCategory
  message   String
  status    SupportStatus   @default(open)
  reply     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model CoachRating {
  id        String         @id @default(cuid())
  studentId String         @unique
  coachId   String
  stars     Int
  comment   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  coach     CoachProfile   @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@map("coach_ratings")
}

model OnlineExam {
  id            String            @id @default(cuid())
  title         String
  publisher     String
  examType      ResultExamType
  questionCount Int
  answerKey     String[]
  cargoStatus   String            @default("kargoda")
  branchId      String
  createdAt     DateTime          @default(now())
  branch        Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  submissions   OptikSubmission[]

  @@index([branchId])
  @@map("online_exams")
}

model OptikSubmission {
  id        String         @id @default(cuid())
  examId    String
  studentId String
  answers   String[]
  correct   Int
  wrong     Int
  blank     Int
  net       Float
  createdAt DateTime       @default(now())
  exam      OnlineExam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([studentId])
  @@map("optik_submissions")
}

model MotivationMessage {
  id        String         @id @default(cuid())
  studentId String
  coachId   String
  body      String
  createdAt DateTime       @default(now())
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("motivation_messages")
}

enum ThreadKind {
  dm
  group
}

model ThreadMember {
  id       String        @id @default(cuid())
  threadId String
  userId   String
  thread   MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
  @@map("thread_members")
}

enum CoachTaskPriority {
  high
  med
  low
}

model CoachTask {
  id        String            @id @default(cuid())
  coachId   String
  studentId String?
  text      String
  due       String?
  done      Boolean           @default(false)
  priority  CoachTaskPriority @default(med)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  coach     CoachProfile      @relation(fields: [coachId], references: [id], onDelete: Cascade)
  student   StudentProfile?   @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([coachId])
  @@index([studentId])
  @@map("coach_tasks")
}

model CoachAnnouncement {
  id        String       @id @default(cuid())
  coachId   String
  title     String
  body      String
  audience  String
  reach     Int          @default(0)
  createdAt DateTime     @default(now())
  coach     CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@map("coach_announcements")
}
