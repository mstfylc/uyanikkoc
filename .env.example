NODE_ENV=development
# Yerel DB: docker compose -f docker-compose.dev.yml up -d
DATABASE_URL=postgresql://uyanik:uyanik123@localhost:5432/uyanik

# Production zorunlu: AUTH_SECRET veya NEXTAUTH_SECRET bos olamaz.
# Uretim degeri icin: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=
AUTH_URL=http://localhost:3010
NEXTAUTH_URL=http://localhost:3010
SINGLE_BRANCH_MODE=true
DEFAULT_ORGANIZATION_ID=
DEFAULT_BRANCH_ID=

# Sadece development icindir. Production'da mutlaka false olmali;
# NODE_ENV=production iken true/1 verilirse uygulama fail-fast yapar.
DEMO_AUTH_ALLOW_IN_MEMORY=true
AI_COACH_ENABLED=false
OPENAI_API_KEY=
KOC_UPLOAD_DIR=./uploads
KOC_LOG_DIR=./logs

# --- Mobil token oturumu (apps/mobile) ---
# Bellek modunda (DEMO_AUTH_ALLOW_IN_MEMORY=true) dev fallback kullanılır;
# production'da JWT_ACCESS_SECRET ve OTP_PEPPER zorunludur (32+ bayt).
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
OTP_PEPPER=
# SMS sağlayıcı (TR): netgsm | iletimerkezi | twilio | mock (bellek modunda dev log)
SMS_PROVIDER=mock
SMS_API_USER=
SMS_API_KEY=
SMS_SENDER_TITLE=UYANIKKOC
# Push (APNs/FCM) — native build aşamasında
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.uyanikkoc.app
FCM_PROJECT_ID=
