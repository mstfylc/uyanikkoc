{
  "$meta": {
    "name": "Uyanik Koc Mobil — Design Tokens",
    "version": "3.0.0",
    "canonical": true,
    "platform": "React Native / Expo (apps/mobile)",
    "source": "mobile/uk-mobile.css (.uk-m :root + [data-theme=dark])",
    "description": "TEK dogruluk kaynagi. Prototipte CSS degiskenleri color-mix ile turetilir; burada React Native icin DUZ (flat) hex/rgba degerlere cozuldu. Marka web ile ORTAK (#534AB7).",
    "brand": "#534AB7",
    "themes": ["light", "dark"],
    "webParity": "Marka + light semantik + neutral token'lar web (uyanikkoc-web-source-v5) ile BIREBIR ayni (muted #6B6F85 dahil). Dark notrlar mobile icin hafif ayri (OLED) — bkz. $platformNotes.",
    "$platformNotes": {
      "primaryTones": "Prototipte primary-600/700/300/soft/glow tek --primary'den color-mix ile turetilir (Tweaks aksan degisince yeniden uretilir). Asagidaki degerler varsayilan marka #534AB7 (dark: #8079E6) icin cozulmus halidir.",
      "darkNeutrals": "Dark surface/border/muted mobilde web'den hafif farklidir (mobil OLED tonlamasi) — kasitli platform sapmasi.",
      "radiusScale": "radius.scale (Keskin .5 / Standart 1 / Yuvarlak 1.5) Tweaks'ten gelir; nihai yaricap = base * scale.",
      "shadowsRN": "CSS box-shadow RN'de dogrudan calismaz; shadow.elevation RN map'i kullanin."
    }
  },

  "color": {
    "light": {
      "primary": "#534AB7",
      "primary-600": "#47409D",
      "primary-700": "#38327C",
      "primary-300": "#9F9AD7",
      "primary-soft": "#ECEBF7",
      "primary-glow": "rgba(83, 74, 183, 0.30)",
      "success": "#0F6E56",
      "success-soft": "#E4F1EC",
      "warning": "#B26A12",
      "warning-soft": "#FAEFDE",
      "danger": "#A32D2D",
      "danger-soft": "#F8E8E8",
      "info": "#2F6BD6",
      "info-soft": "#E6EEFA",
      "bg": "#F4F5FA",
      "surface": "#FFFFFF",
      "surface-2": "#FAFAFD",
      "surface-3": "#F3F4F9",
      "border": "#E8E9F2",
      "border-strong": "#DCDEEA",
      "text": "#181A24",
      "text-2": "#45485A",
      "muted": "#6B6F85",
      "faint": "#A2A6B8",
      "ring": "rgba(83, 74, 183, 0.16)",
      "on-primary": "#FFFFFF"
    },
    "dark": {
      "primary": "#8079E6",
      "primary-600": "#8A84E8",
      "primary-700": "#6963BD",
      "primary-300": "#B0ACF0",
      "primary-soft": "#313256",
      "primary-glow": "rgba(128, 121, 230, 0.32)",
      "success": "#34D399",
      "success-soft": "#14271F",
      "warning": "#F0B45E",
      "warning-soft": "#2A2113",
      "danger": "#F87171",
      "danger-soft": "#2C1818",
      "info": "#6BA0F0",
      "info-soft": "#141E2E",
      "bg": "#0B0E18",
      "surface": "#141723",
      "surface-2": "#181C2A",
      "surface-3": "#1E2233",
      "border": "#262B3D",
      "border-strong": "#313752",
      "text": "#F3F4FB",
      "text-2": "#C3C7DA",
      "muted": "#8A8FA8",
      "faint": "#62677E",
      "ring": "rgba(128, 121, 230, 0.22)",
      "on-primary": "#FFFFFF"
    }
  },

  "typography": {
    "fontFamily": {
      "default": "Plus Jakarta Sans",
      "options": ["Plus Jakarta Sans", "Manrope", "Nunito"],
      "stack": "\"Plus Jakarta Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
    },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "extrabold": 800 },
    "scale": {
      "pageTitle":    { "size": 26, "weight": 800, "lineHeight": 31, "letterSpacing": -0.65 },
      "greetingName": { "size": 19, "weight": 800, "lineHeight": 22, "letterSpacing": -0.38 },
      "heroTitle":    { "size": 20, "weight": 800, "lineHeight": 25, "letterSpacing": -0.40 },
      "statValue":    { "size": 26, "weight": 800, "lineHeight": 26, "letterSpacing": -0.52 },
      "sectionTitle": { "size": 16, "weight": 800, "lineHeight": 20, "letterSpacing": -0.32 },
      "cardTitle":    { "size": 14.5, "weight": 700, "lineHeight": 19, "letterSpacing": -0.15 },
      "body":         { "size": 14, "weight": 500, "lineHeight": 20 },
      "label":        { "size": 13, "weight": 800, "lineHeight": 16 },
      "subtle":       { "size": 13, "weight": 600, "lineHeight": 17 },
      "meta":         { "size": 11.5, "weight": 600, "lineHeight": 15 },
      "tabLabel":     { "size": 10.5, "weight": 700, "lineHeight": 13, "letterSpacing": -0.1 }
    }
  },

  "spacing": {
    "$note": "8pt tabanli; ekran yatay padding 20, kart padding 18.",
    "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "5": 18, "6": 20, "7": 22, "8": 26, "9": 32,
    "screenX": 20, "cardPad": 18, "sectionGap": 12, "sectionGapLg": 22
  },

  "radius": {
    "$note": "nihai = base * scale. scale Tweaks'ten gelir.",
    "scale": { "Keskin": 0.5, "Standart": 1, "Yuvarlak": 1.5, "default": 1 },
    "base": {
      "chip": 8, "badge": 8, "button": 12, "buttonBlock": 15, "seg": 11,
      "iconBtn": 13, "input": 15, "odev": 16, "list": 18, "card": 20,
      "hero": 24, "sheet": 26, "pill": 999
    }
  },

  "iconSize": { "xs": 13, "sm": 16, "md": 19, "lg": 22, "tab": 24, "xl": 26 },

  "elevation": {
    "$note": "RN icin shadowColor/Opacity/Radius/Offset (+Android elevation). CSS karsiligi shadow.css altinda.",
    "sm": { "shadowColor": "#181A28", "shadowOpacity": 0.06, "shadowRadius": 3,  "shadowOffsetY": 1,  "elevation": 1 },
    "md": { "shadowColor": "#181A28", "shadowOpacity": 0.08, "shadowRadius": 12, "shadowOffsetY": 4,  "elevation": 4 },
    "lg": { "shadowColor": "#181A28", "shadowOpacity": 0.14, "shadowRadius": 24, "shadowOffsetY": 12, "elevation": 10 },
    "primary": { "shadowColor": "#534AB7", "shadowOpacity": 0.30, "shadowRadius": 20, "shadowOffsetY": 10, "elevation": 8 }
  },
  "shadowCss": {
    "light": {
      "sm": "0 1px 2px rgba(24,26,40,.05), 0 1px 3px rgba(24,26,40,.04)",
      "md": "0 2px 6px rgba(24,26,40,.06), 0 8px 24px rgba(24,26,40,.06)",
      "lg": "0 12px 40px rgba(24,26,40,.14)",
      "primary": "0 10px 28px -8px rgba(83,74,183,.30)"
    },
    "dark": {
      "sm": "0 1px 2px rgba(0,0,0,.30)",
      "md": "0 2px 8px rgba(0,0,0,.32), 0 12px 32px rgba(0,0,0,.28)",
      "lg": "0 18px 48px rgba(0,0,0,.45)",
      "primary": "0 12px 30px -8px rgba(128,121,230,.32)"
    }
  },

  "device": {
    "$note": "Hedef cihazlar (CSS px = mantiksal dp). safeTop/Bottom prototip degerleri; URETIMDE env(safe-area-inset-*) kullanin.",
    "target": "iPhone 16 Pro (402x874)",
    "safeAreaProd": { "top": "max(env(safe-area-inset-top), 20px)", "bottom": "max(env(safe-area-inset-bottom), 12px)" },
    "profiles": {
      "iOS · SE":          { "os": "ios", "w": 375, "h": 667, "safeTop": 24, "safeBottom": 14 },
      "iOS · Standart":    { "os": "ios", "w": 393, "h": 852, "safeTop": 56, "safeBottom": 30 },
      "iOS · Pro":         { "os": "ios", "w": 402, "h": 874, "safeTop": 56, "safeBottom": 30 },
      "iOS · Pro Max":     { "os": "ios", "w": 440, "h": 956, "safeTop": 60, "safeBottom": 32 },
      "Android · Kompakt": { "os": "android", "w": 360, "h": 800, "safeTop": 8, "safeBottom": 10 },
      "Android · Standart":{ "os": "android", "w": 412, "h": 915, "safeTop": 8, "safeBottom": 10 },
      "Android · Buyuk":   { "os": "android", "w": 432, "h": 960, "safeTop": 10, "safeBottom": 12 }
    }
  }
}
